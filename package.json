  "bugs": {
    "url": "https://github.com/RodrigoPBernardo/restaurant-saas-types-/issues"
  },
  "homepage": "https://github.com/RodrigoPBernardo/restaurant-saas-types-#readme",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}